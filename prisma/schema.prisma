// Modelo completo del sprint 1.
// User/Session/Account vendrán en sprint 2 (Better Auth los gestiona).
// Aquí solo declaramos User mínimo como placeholder para ownerId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  es
  ca
  en
  fr
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
}

enum BusinessStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum Plan {
  FREE
  FEATURED
  PREMIUM
}

enum PriceRange {
  CHEAP
  MID
  HIGH
  LUXURY
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  emailVerified    Boolean  @default(false)
  name             String?
  image            String?
  role             UserRole @default(OWNER)
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  businesses Business[] @relation("BusinessOwner")
  reviews    Review[]
  posts      Post[]
  sessions   Session[]
  accounts   Account[]
}

// ===== Better Auth =====
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
}

model Category {
  id         String     @id @default(cuid())
  key        String     @unique
  parentId   String?
  parent     Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryTree")
  icon       String?
  order      Int        @default(0)
  schemaType String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  translations CategoryTranslation[]
  businesses   Business[]

  @@index([parentId, order])
}

model CategoryTranslation {
  id             String   @id @default(cuid())
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale         Locale
  name           String
  slug           String
  description    String?  @db.Text
  seoTitle       String?
  seoDescription String?

  @@unique([categoryId, locale])
  // Slug no es único globalmente: se resuelve por jerarquía (padre + slug),
  // así "familiares" puede existir en hoteles y restaurantes.
  @@index([locale, slug])
}

model Business {
  id         String         @id @default(cuid())
  ownerId    String?
  owner      User?          @relation("BusinessOwner", fields: [ownerId], references: [id])
  categoryId String
  category   Category       @relation(fields: [categoryId], references: [id])
  status     BusinessStatus @default(DRAFT)
  plan       Plan           @default(FREE)
  featured   Boolean        @default(false)
  verified   Boolean        @default(false)

  phone     String?
  email     String?
  website   String?
  whatsapp  String?
  instagram String?
  facebook  String?
  tiktok    String?

  address    String?
  postalCode String?
  district   String?
  lat        Decimal? @db.Decimal(9, 6)
  lng        Decimal? @db.Decimal(9, 6)

  priceRange     PriceRange?
  capacity       Int?
  amenities      String[]
  paymentMethods String[]

  ratingAvg   Float?
  ratingCount Int    @default(0)
  viewCount   Int    @default(0)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  translations BusinessTranslation[]
  hours        OpeningHours[]
  media        Media[]
  reviews      Review[]
  tags         TagOnBusiness[]
  slugHistory  BusinessSlugHistory[]
  subscription Subscription?

  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([status, featured, publishedAt(sort: Desc)])
  @@index([status, plan, featured])
  @@index([lat, lng])
}

model BusinessTranslation {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locale           Locale
  slug             String
  name             String
  shortDescription String?
  description      String?  @db.Text
  seoTitle         String?
  seoDescription   String?

  @@unique([businessId, locale])
  @@unique([locale, slug])
}

model BusinessSlugHistory {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  locale     Locale
  oldSlug    String
  changedAt  DateTime @default(now())

  @@unique([locale, oldSlug])
}

model OpeningHours {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  dayOfWeek  Int
  openTime   String
  closeTime  String
  note       String?

  @@index([businessId, dayOfWeek])
}

model Media {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       MediaType @default(IMAGE)
  key        String
  url        String
  alt        String?
  width      Int?
  height     Int?
  position   Int       @default(0)
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([businessId, position])
}

model Tag {
  id           String           @id @default(cuid())
  key          String           @unique
  translations TagTranslation[]
  businesses   TagOnBusiness[]
}

model TagTranslation {
  id     String @id @default(cuid())
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  locale Locale
  name   String
  slug   String

  @@unique([tagId, locale])
  @@unique([locale, slug])
}

model TagOnBusiness {
  businessId String
  tagId      String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([businessId, tagId])
  @@index([tagId, businessId])
}

model Review {
  id         String       @id @default(cuid())
  businessId String
  business   Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  rating     Int
  title      String?
  body       String       @db.Text
  locale     Locale
  status     ReviewStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  reply      String?      @db.Text
  replyAt    DateTime?

  @@unique([businessId, userId])
  @@index([businessId, status, createdAt(sort: Desc)])
}

model Post {
  id           String            @id @default(cuid())
  status       PostStatus        @default(DRAFT)
  authorId     String
  author       User              @relation(fields: [authorId], references: [id])
  publishedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  translations PostTranslation[]

  @@index([status, publishedAt(sort: Desc)])
}

model PostTranslation {
  id             String  @id @default(cuid())
  postId         String
  post           Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  locale         Locale
  slug           String
  title          String
  excerpt        String?
  content        String  @db.Text
  cover          String?
  seoTitle       String?
  seoDescription String?

  @@unique([postId, locale])
  @@unique([locale, slug])
}

model Redirect {
  id        String    @id @default(cuid())
  fromPath  String    @unique
  toPath    String
  code      Int       @default(301)
  hits      Int       @default(0)
  lastHitAt DateTime?
  createdAt DateTime  @default(now())
}

model Subscription {
  id                 String    @id @default(cuid())
  businessId         String    @unique
  business           Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan               Plan
  stripeCustomerId   String?
  stripeSubId        String?   @unique
  stripePriceId      String?
  status             String
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([stripeCustomerId])
}
